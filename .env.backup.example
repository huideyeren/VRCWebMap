# PostgreSQL
BACKUP_PGDATABASE=vrcwebmap
BACKUP_PGUSER=vrcwebmap
BACKUP_PGPASSWORD=replace-with-database-password

# AWS S3 / Wasabi / S3-compatible storage
S3_BUCKET=replace-with-backup-bucket
S3_PREFIX=backups
S3_ENDPOINT_URL=https://s3.example.com
S3_ADDRESSING_STYLE=path
ALLOW_INSECURE_S3_ENDPOINT=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace-with-access-key
AWS_SECRET_ACCESS_KEY=replace-with-secret-key
AWS_SESSION_TOKEN=

# Complete generations retained after each successful backup
BACKUP_RETENTION_COUNT=4
